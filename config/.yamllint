extends: default

rules:
  # Modern defaults for this project
  line-length:
    max: 120
    level: error

  document-start: disable

  indentation:
    spaces: 2
    indent-sequences: true
    check-multi-line-strings: false

  empty-lines:
    max: 1
    max-end: 1

  new-line-at-end-of-file:
    level: error

  trailing-spaces:
    level: error

  truthy:
    check-keys: false

ignore: |
  **/.venv/**
  **/build/**
  **/.tmp*/
  **/node_modules/**
  **/dist/**
  **/.omp/**  # agentic orchestration, not product
