{
    "venvPath": ".",
    "extraPaths": ["src", "."],
    # All report* flags set to "none" because custom pylint checkers (conformance/*)
    # provide more precise type-level diagnostics than pyright's generic type warnings
    "reportAttributeAccessIssue": "none",
    "reportReturnType": "none",
    "reportAssignmentType": "none",
    "reportGeneralTypeIssues": "none",
    "reportOptionalMemberAccess": "none",
    "exclude": [
        ".venv",
        "**/__pycache__",
        "**/node_modules",
        "**/.*",
        "build/",
        "tests/data/"
    ]
}
