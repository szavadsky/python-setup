[MAIN]
max-module-lines=500
ignore-paths=test\.data,tests\.data,tests/,\.venv,__pycache__,node_modules,build/,.tmp*/
ignore-patterns=.*\.pyi$
source-roots=src
load-plugins=python_setup_lint.checkers.conformance.no_try_import_checker,python_setup_lint.checkers.conformance.beartype_checker,python_setup_lint.checkers.stub.checker,python_setup_lint.checkers.stub.docstring_checker,python_setup_lint.checkers.conformance.tmp_path_checker,python_setup_lint.checkers.conformance.asyncio_timeout_checker,python_setup_lint.checkers.conformance.suppression_justification_checker,python_setup_lint.checkers.conformance.unnamed_tuple_dict_checker,python_setup_lint.checkers.conformance.generic_key_dict_checker,python_setup_lint.checkers.conformance.pyi_underscore_checker,python_setup_lint.checkers.conformance.structlog_checker,python_setup_lint.checkers.conformance.missing_error_chain_checker,python_setup_lint.checkers.conformance.trivial_wrapper_checker,python_setup_lint.checkers.conformance.redundant_type_guard_checker,python_setup_lint.checkers.conformance.bare_except_comment_checker,python_setup_lint.checkers.conformance.missing_return_annotation_checker,python_setup_lint.checkers.conformance.silent_except_checker

[MESSAGES CONTROL]
# reason: Disabled built-in checks that conflict with project conventions or are
# superseded by custom conformance checkers. Grouped by rationale:
#   - Tests exempt from docstring rules: missing-function-docstring, missing-module-docstring, missing-class-docstring
#   - Custom rules supersede builtins: invalid-name, impl-missing-annotation, use-implicit-booleaness-not-comparison, stub-symbol-missing (superseded by custom stub checker), useless-import-alias (re-exports need `as` for mypy strict re-export visibility)
#   - Test/script patterns: import-outside-toplevel, redefined-outer-name, reimported, global-statement, cyclic-import
#   - False positives in dynamic code: unused-argument, unused-import, unused-variable, cell-var-from-loop, protected-access
#   - Style preferences: line-too-long, trailing-newlines, too-many-arguments, too-many-return-statements, too-few-public-methods, superfluous-parens, wrong-import-order, bad-indentation, unnecessary-ellipsis, unnecessary-dunder-call
enable=too-many-statements,too-many-branches,too-many-locals,too-many-nested-blocks,too-many-public-methods,too-complex,no-try-import,missing-beartype,tempfile-mkdtemp-in-test,asyncio-timeout,missing-module-stub,missing-import-declaration,missing-module-stub-for-import,star-import-unresolvable,signature-mismatch,annotation-mismatch,impl-missing-annotation,annotation-unverifiable,symbol-kind-mismatch,pyi-underscore-symbol,use-structlog,docstring-in-impl,generic-return-requires-returns,unjustified-suppression,unnamed-tuple-dict-value,generic-key-dict,use-structured-logging,missing-error-chain,trivial-wrapper,redundant-type-guard,bare-except-comment,missing-return-annotation,silent-except
#   - Parser quirk: unknown-option-value, unspecified-encoding
disable=unknown-option-value,unused-argument,broad-exception-caught,protected-access,missing-function-docstring,line-too-long,import-outside-toplevel,trailing-newlines,too-many-arguments,unspecified-encoding,unused-import,cell-var-from-loop,too-many-return-statements,too-few-public-methods,superfluous-parens,wrong-import-order,unused-variable,missing-module-docstring,missing-class-docstring,invalid-name,global-statement,cyclic-import,bad-indentation,unnecessary-ellipsis,unnecessary-dunder-call,redefined-outer-name,reimported,use-implicit-booleaness-not-comparison,useless-import-alias,stub-symbol-missing

[DESIGN]
max-statements=65
max-branches=16
max-locals=20
max-nested-blocks=8
max-public-methods=30
max-attributes=15

[SIMILARITIES]
min-similarity-lines=10
ignore-comments=yes
ignore-docstrings=yes
ignore-imports=yes

[STUB-CHECKER]
source-roots=src
test-patterns=tests/,test_*.py,*_test.py,conftest.py
stub-roots=
star-import-policy=error
