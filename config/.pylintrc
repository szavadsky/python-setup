[MAIN]
max-module-lines=500
ignore-paths=tests/data/,.venv,__pycache__,node_modules,build/,.tmp*/
source-roots=src
load-plugins=python_setup_lint.checkers.no_try_import_checker,python_setup_lint.checkers.beartype_checker,python_setup_lint.checkers.stub_checker,python_setup_lint.checkers.stub_docstring_checker,python_setup_lint.checkers.tmp_path_checker,python_setup_lint.checkers.asyncio_timeout_checker

[MESSAGES CONTROL]
disable=unknown-option-value,unused-argument,broad-exception-caught,protected-access,missing-function-docstring,line-too-long,import-outside-toplevel,trailing-newlines,too-many-arguments,unspecified-encoding,unused-import,cell-var-from-loop,too-many-return-statements,too-few-public-methods,superfluous-parens,wrong-import-order,unused-variable,missing-module-docstring,missing-class-docstring,invalid-name,impl-missing-annotation,global-statement,cyclic-import,bad-indentation,unnecessary-ellipsis,unnecessary-dunder-call,redefined-outer-name,reimported,use-implicit-booleaness-not-comparison
enable=too-many-statements,too-many-branches,too-many-locals,too-many-nested-blocks,too-many-public-methods,too-complex,no-try-import,missing-beartype,tempfile-mkdtemp-in-test,asyncio-timeout,missing-module-stub,missing-import-declaration,missing-module-stub-for-import,star-import-unresolvable,signature-mismatch,annotation-mismatch,impl-missing-annotation,annotation-unverifiable,stub-symbol-missing,symbol-kind-mismatch,duplicate-code

[DESIGN]
max-statements=65
max-branches=16
max-locals=20
max-nested-blocks=8
max-public-methods=30
max-complexity=15
max-attributes=15

[SIMILARITIES]
min-similarity-lines=10
ignore-comments=yes
ignore-docstrings=yes
ignore-imports=yes

[STUB-CHECKER]
source-roots=src
test-patterns=tests/,test_*.py,*_test.py,conftest.py
stub-roots=
star-import-policy=error
